{
  "family": "lwaye-migrate",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::128055990601:role/lwaye-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::128055990601:role/lwaye-api-task-role",
  "containerDefinitions": [
    {
      "name": "migrate",
      "image": "REPLACE_ME",
      "essential": true,
      "command": ["npm", "run", "migrate", "--workspace", "@lwaye/api"],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "SMS_PROVIDER", "value": "twilio" },
        { "name": "STORAGE_PROVIDER", "value": "s3" },
        { "name": "PUSH_PROVIDER", "value": "expo" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:ssm:us-east-2:128055990601:parameter/lwaye/staging/api/database-url" },
        { "name": "TWILIO_ACCOUNT_SID", "valueFrom": "arn:aws:ssm:us-east-2:128055990601:parameter/lwaye/staging/api/twilio-account-sid" },
        { "name": "TWILIO_AUTH_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-2:128055990601:secret:lwaye/staging/api/twilio-auth-token" },
        { "name": "TWILIO_FROM_PHONE", "valueFrom": "arn:aws:ssm:us-east-2:128055990601:parameter/lwaye/staging/api/twilio-from-phone" },
        { "name": "S3_BUCKET", "valueFrom": "arn:aws:ssm:us-east-2:128055990601:parameter/lwaye/staging/api/s3-bucket" },
        { "name": "S3_REGION", "valueFrom": "arn:aws:ssm:us-east-2:128055990601:parameter/lwaye/staging/api/s3-region" },
        { "name": "S3_ACCESS_KEY_ID", "valueFrom": "arn:aws:secretsmanager:us-east-2:128055990601:secret:lwaye/staging/api/s3-access-key-id" },
        { "name": "S3_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:128055990601:secret:lwaye/staging/api/s3-secret-access-key" },
        { "name": "S3_PUBLIC_BASE_URL", "valueFrom": "arn:aws:ssm:us-east-2:128055990601:parameter/lwaye/staging/api/s3-public-base-url" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/lwaye-migrate",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
